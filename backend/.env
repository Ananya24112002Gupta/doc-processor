# Application
APP_ENV=development
SECRET_KEY=supersecretkey_change_in_production_please

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://docflow:docflow@localhost:5432/docflow
DATABASE_URL_SYNC=postgresql://docflow:docflow@localhost:5432/docflow

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# File storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
